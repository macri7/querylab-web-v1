---
import { copyrightConfig, navBarConfig } from "../../config";
const links = navBarConfig.links.filter(
	(l): l is { name: string; url: string } => typeof l !== "number",
);
---
<footer class="ql-footer">
	<div class="ql-footer-inner">
		<div class="ql-footer-brand">
			<span class="ql-footer-title">Query&nbsp;Lab</span>
			<span class="ql-footer-sub">Universidad de Lima · Curso de SQL</span>
		</div>

		<nav class="ql-footer-nav" aria-label="Navegación del pie">
			{links.map((l) => (
				<a href={l.url}>{l.name}</a>
			))}
		</nav>

		<div class="ql-footer-meta">
			<span>&copy; {copyrightConfig.startYear}–{copyrightConfig.endYear} {copyrightConfig.siteName}</span>
			<span>
				Hecho con
				<a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
			</span>
		</div>
	</div>
</footer>

<style>
	.ql-footer {
		width: 100%;
		background: var(--card-bg);
		border-top: 3px solid var(--primary);
		color: var(--deep-text);
	}
	.ql-footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 2.25rem 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		align-items: flex-start;
	}
	@media (min-width: 768px) {
		.ql-footer-inner {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
	.ql-footer-brand { display: flex; flex-direction: column; gap: 0.25rem; }
	.ql-footer-title {
		font-weight: 800;
		font-size: 1.15rem;
		letter-spacing: 0.01em;
		color: var(--deep-text);
	}
	.ql-footer-sub {
		font-size: 0.82rem;
		color: var(--lt-muted, #6b6456);
	}
	.ql-footer-nav { display: flex; flex-wrap: wrap; gap: 1.5rem; }
	.ql-footer-nav a {
		color: var(--deep-text);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		transition: color 0.15s;
	}
	.ql-footer-nav a:hover { color: var(--primary); }
	.ql-footer-meta {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		font-size: 0.78rem;
		color: var(--lt-muted, #6b6456);
	}
	@media (min-width: 768px) {
		.ql-footer-meta { text-align: right; }
	}
	.ql-footer-meta a {
		color: var(--primary);
		text-decoration: none;
		font-weight: 700;
	}
	.ql-footer-meta a:hover { text-decoration: underline; }
</style>
